
def creditcard_available(creditcard_number:str):
    creditcard_number_rev = creditcard_number[::-1]
    total_nums = 0
    for i in range(len(creditcard_number_rev)):
        if i % 2 == 1:
            nums = int(creditcard_number_rev[i]) * 2
            if nums > 9: nums -= 9
        else:
            nums = int(creditcard_number_rev[i])
        total_nums += nums

    if total_nums != 0 and total_nums % 10 == 0: return True, creditcard_number

    return False, creditcard_number


'''
VISA 開頭4
mastercard 開頭51~55
JCB 開頭3528~3589
'''
def company_name(creditcard_number:str):
    target = creditcard_number[0]
    match target:
        # visa
        case '4': company = 'visa'
        # mastercard
        case '5':
            if int(creditcard_number[:2]) >= 51 and int(creditcard_number[:2]) <= 55:
                company = 'mastercard'
            else:
                company = 'other'
        # jcb
        case '3':
            if int(creditcard_number[:4]) >= 3528 and int(creditcard_number[:4]) <= 3589:
                company = 'jcb'
            else:
                company = 'other'
        case _ :
            company = 'other'

    return company


